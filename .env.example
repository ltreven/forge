# ── API / Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=<CHANGE_THIS_TO_A_SECURE_RANDOM_STRING>
CORS_ORIGIN=http://localhost:3000

# ── Platform AI credentials (fallback for all agents) ───────────────────────────
# Agents without their own API key will use these platform-level credentials.
# NEVER commit real keys — this file is gitignored. Copy from .env.example.
PLATFORM_OPENAI_API_KEY=<YOUR-KEY>
PLATFORM_MODEL_PROVIDER=openai
PLATFORM_MODEL_NAME=gpt-4o-mini

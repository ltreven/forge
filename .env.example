# Local MVP environment template for eDEV
# Copy to .env and fill with local values. Do not commit real secrets.

# OpenClaw / model provider
OPENAI_API_KEY=

# Telegram (optional for the first local MVP if not testing Telegram yet)
TELEGRAM_BOT_TOKEN=

# Local gateway auth
OPENCLAW_GATEWAY_TOKEN=change-me

# Optional project-management integration
LINEAR_API_KEY=

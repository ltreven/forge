# ── API / Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=<CHANGE_THIS_TO_A_SECURE_RANDOM_STRING>
CORS_ORIGIN=http://localhost:3000

# ── Platform AI credentials (fallback for all agents) ───────────────────────────
# Agents without their own API key will use these platform-level credentials.
# NEVER commit real keys — this file is gitignored. Copy from .env.example.
PLATFORM_OPENAI_API_KEY=<YOUR-KEY>
PLATFORM_MODEL_PROVIDER=openai
PLATFORM_MODEL_NAME=gpt-4o-mini

# ── RabbitMQ (message bus between control plane and agent pods) ──────────────────
# In local dev (Tilt): these are set via values-local.yaml, not .env.
# When running forge-api outside k8s (e.g. bare-metal dev), set these manually.
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASSWORD=forge_rabbit_local
RABBITMQ_AMQP_HOST=localhost
RABBITMQ_AMQP_PORT=5672

# tilt-settings.yaml
#
# Local developer overrides for the Tiltfile.
# This file is gitignored — copy this example and customize it.
#
# Usage: cp tilt-settings.yaml.example tilt-settings.yaml

# Custom image names (useful if using a local registry like kind or k3d)
# api_image: localhost:5000/forge-api
# web_image: localhost:5000/forge-web

# Override the local hostname for the Ingress
# host: forge.localhost

# To use a different kubeconfig context:
# allow_k8s_contexts: ["docker-desktop", "my-dev-cluster"]

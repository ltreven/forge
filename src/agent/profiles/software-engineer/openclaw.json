{
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "models": {
        "openai/gpt-5.4": {
          "alias": "GPT"
        }
      },
      "workspace": "/home/node/workspace",
      "system": "You are the eDEV Software Engineer Agent. Read SOUL.md and AGENTS.md in your workspace on startup to understand your persona and mission."
    }
  },
  "mcp": {
    "clients": {
      "linear": {
        "command": "npx",
        "args": [
          "-y",
          "@smithery/cli@latest",
          "run",
          "@smithery/linear-mcp"
        ],
        "env": {
          "LINEAR_API_KEY": "${LINEAR_API_KEY}"
        }
      }
    }
  },
  "tools": {
    "profile": "coding"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "name": "eDEV-K8s",
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  }
}

{
  "auth": {
    "profiles": {
      "__AUTH_PROFILE_ID__": {
        "provider": "__AUTH_PROVIDER__",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "__MODEL_NAME__"
      },
      "models": {
        "__MODEL_NAME__": {
          "alias": "__MODEL_ALIAS__"
        }
      },
      "workspace": "__WORKSPACE_DIR__",
      "system": "You are the eDEV Software Engineer Agent. Read SOUL.md and AGENTS.md in your workspace on startup to understand your persona and mission."
    }
  },
  "mcp": {
    "clients": {
      "linear": {
        "command": "npx",
        "args": [
          "-y",
          "@smithery/cli@latest",
          "run",
          "@smithery/linear-mcp"
        ],
        "env": {
          "LINEAR_API_KEY": "__LINEAR_API_KEY__"
        }
      }
    }
  },
  "tools": {
    "profile": "__TOOLS_PROFILE__"
  },
  "session": {
    "dmScope": "__SESSION_DM_SCOPE__"
  },
  "gateway": {
    "name": "eDEV-K8s",
    "mode": "local",
    "port": __GATEWAY_PORT__,
    "bind": "__GATEWAY_BIND__",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  }
}
